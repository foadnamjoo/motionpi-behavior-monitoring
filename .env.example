# Copy to .env and set your MongoDB connection string.
# Do not commit .env or any real credentials.
#
# Common local SSH tunnel pattern:
# 1) Open SSH tunnel so local 127.0.0.1:27017 forwards to remote MongoDB.
# 2) Use this URI format:
# MONGODB_URI=mongodb://admin:YOUR_MONGODB_PASSWORD@127.0.0.1:27017/?authSource=admin&directConnection=true
#
# If your password has special characters (@ : / # % ? &), URL-encode it first.

MONGODB_URI=mongodb://admin:YOUR_MONGODB_PASSWORD@127.0.0.1:27017/?authSource=admin&directConnection=true
