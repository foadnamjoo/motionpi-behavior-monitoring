# Copy to .env and set your MongoDB connection string (same as in MongoDB Compass).

# Direct connection (no SSH), e.g. CHPC motionpi or any host:port:
MONGODB_URI=mongodb://YOUR_DB_HOST:27017

# Or MongoDB Atlas: copy your connection string from the Atlas UI (Connect > Drivers) and set MONGODB_URI=

# Optional: only if the server is not reachable directly, use SSH tunnel (./ssh-mongodb-tunnel.sh) then:
# MONGODB_URI=mongodb://localhost:27017
